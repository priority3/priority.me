---
import { getCollection, render } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import MobileNav from '@/components/MobileNav.astro'
import TableOfContents from '@/components/TableOfContents.astro'
import { formatDisplayDate } from '@/lib/posts'

export async function getStaticPaths() {
  const posts = await getCollection('blogs')
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content, headings } = await render(post)
const { title, desc, date, language, subtitle } = post.data
---

<BaseLayout
  title={title}
  description={desc ?? title}
  path="/posts"
>
  <MobileNav path="/posts" />

  <article>
    <header class="article-header">
      <h1 class="article-title">{title}</h1>
      {(subtitle || desc) && (
        <p class="article-subtitle">{subtitle ?? desc}</p>
      )}
      <div class="article-meta">
        <time datetime={date.toISOString()}>{formatDisplayDate(date)}</time>
        {language && <span class="accent">{language}</span>}
      </div>
    </header>

    <TableOfContents headings={headings} />

    <div class="prose">
      <Content />
    </div>

    <a class="back-link" href="/posts">← 返回文稿</a>
  </article>
</BaseLayout>
