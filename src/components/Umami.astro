---
/**
 * Inject Umami analytics only when both public env vars are set.
 * Leave unset in local/dev to avoid noise; set on Netlify for production.
 *
 *   PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
 *   PUBLIC_UMAMI_WEBSITE_ID=<your-website-id>
 */
const src = import.meta.env.PUBLIC_UMAMI_SRC as string | undefined
const websiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID as string | undefined
const enabled = Boolean(src && websiteId)
---

{enabled && (
  <script
    is:inline
    defer
    src={src}
    data-website-id={websiteId}
  />
)}
