---
/**
 * "PR." signature mark for the site header.
 * Flowing script + underline flourish; draws in once on load
 * (same spirit as the old raze SVG wordmark).
 */
---

<svg
  class="brand-mark"
  width="82"
  height="40"
  viewBox="0 0 164 80"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path
    class="brand-mark__flourish"
    d="M20 60 C52 72, 104 70, 146 54"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
  />
  <text class="brand-mark__text" x="10" y="54" fill="currentColor">PR.</text>
</svg>

<style>
  .brand-mark {
    display: block;
    color: var(--color-neutral-10);
    overflow: visible;
    transition: color 0.2s var(--ease-breathe);
  }

  a:hover .brand-mark {
    color: var(--color-accent);
  }

  .brand-mark__text {
    font-family: 'Great Vibes', 'Segoe Script', 'Apple Chancery', cursive;
    font-size: 58px;
    letter-spacing: 0.04em;
  }

  .brand-mark__flourish {
    opacity: 0.38;
  }

  @media (prefers-reduced-motion: no-preference) {
    .brand-mark__text {
      opacity: 0;
      animation: pr-in 0.9s var(--ease-breathe) 0.05s forwards;
    }

    .brand-mark__flourish {
      stroke-dasharray: 200;
      stroke-dashoffset: 200;
      animation: pr-flourish 1.1s var(--ease-breathe) 0.2s forwards;
    }
  }

  @keyframes pr-in {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pr-flourish {
    to {
      stroke-dashoffset: 0;
    }
  }
</style>
