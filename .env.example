# Copy to .env for local; set the same keys in Netlify → Site settings → Environment variables.
# Never commit real secrets.

# --- Umami (optional analytics) ---
# PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
# PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PUBLIC_UMAMI_SRC=
PUBLIC_UMAMI_WEBSITE_ID=

# --- Presence (ProcessReporter → site header chip) ---
# Shared secret: ProcessReporter MixSpace destination uses this as apiToken / body.key
# PRESENCE_TOKEN=openssl rand -hex 24
PRESENCE_TOKEN=

# --- Keystatic storage mode ---
# local  = write Markdown on disk (default in `pnpm dev`)
# github = commit via GitHub App (default when NODE_ENV=production)
# KEYSTATIC_STORAGE=local
# KEYSTATIC_STORAGE=github

# --- Keystatic GitHub App (required for online writing on Netlify) ---
# Create at https://github.com/settings/apps/new — see README "Online writing"
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=          # long random string, e.g. openssl rand -hex 32
# PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=   # the app slug from github.com/apps/<slug>
