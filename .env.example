# Copy to .env (gitignored via *.local / never commit secrets if any)
# Umami is optional: leave blank → no analytics script injected.

# Umami Cloud example:
# PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
# PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Self-hosted example:
# PUBLIC_UMAMI_SRC=https://umami.example.com/script.js
# PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

PUBLIC_UMAMI_SRC=
PUBLIC_UMAMI_WEBSITE_ID=
